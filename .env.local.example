# Email Configuration
# Choose either "gmail" or "outlook" for EMAIL_SERVICE
EMAIL_SERVICE=gmail

# Email account that will send the contact form messages
# For Gmail: your full Gmail address (e.g., yourname@gmail.com)
# For Outlook: your full Outlook/Microsoft 365 email (e.g., yourname@outlook.com)
EMAIL_USER=your-email@example.com

# App Password (NOT your regular password!)
# For Gmail:
#   1. Go to myaccount.google.com
#   2. Enable 2-Step Verification if not already enabled
#   3. Go to Security > App passwords
#   4. Generate a password for "Mail" and "Windows Computer"
#   5. Copy the 16-character password here
#
# For Outlook:
#   1. Go to account.microsoft.com
#   2. Go to Security > Advanced security options
#   3. Create an app password
#   4. Copy the password here
EMAIL_PASSWORD=your-app-password-here

# (Optional) Email address where contact form submissions are sent
# If not set, submissions are sent to EMAIL_USER
EMAIL_TO_ADDRESS=nasrin.hooshmand@tamucc.edu
